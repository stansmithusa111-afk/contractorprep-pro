# Supabase — get these from Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase service role key — server-side only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Stripe — get from Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Your domain (for Stripe redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
